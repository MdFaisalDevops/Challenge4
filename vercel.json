{
  "buildCommand": "cd apps/web && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://crowdmind-server-url.run.app/api/:path*"
    }
  ]
}

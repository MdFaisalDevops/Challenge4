{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://crowdmind-server-888634120302.us-central1.run.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://crowdmind-server-888634120302.us-central1.run.app/health"
    }
  ]
}

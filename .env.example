# Backend Express Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000

# Firestore Database Configuration
FIREBASE_PROJECT_ID=crowdmind-ai-dev
FIRESTORE_EMULATOR_HOST=localhost:8080
# For production Firestore connection, set path to credentials JSON:
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Firebase Client SDK Configurations (Public to Web App)
NEXT_PUBLIC_FIREBASE_API_KEY=placeholder-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=crowdmind-ai-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=crowdmind-ai-dev
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps API Configuration (Public to Web App)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
